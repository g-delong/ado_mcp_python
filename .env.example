# Copy this file to .env and fill in real values.
# Do not commit .env (it contains secrets).

# Azure DevOps Personal Access Token (PAT)
ADO_MCP_AUTH_TOKEN=replace_with_your_pat

# Azure DevOps organization short name (not full URL)
ADO_ORG=replace_with_org_name

# Azure DevOps project name or ID
ADO_PROJECT=replace_with_project_name
